@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = null;
    ViewBag.Title = "Şifre Değiştir";
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Şifre Değiştir</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background: #f0f0f0;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .card {
            max-width: 450px;
            width: 100%;
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
        }

        .card-header {
            background: #1a1a1a;
            color: white;
            border-radius: 12px 12px 0 0;
            padding: 20px;
            text-align: center;
        }
    </style>
</head>
<body>
    <div class="card">
        <div class="card-header">
            <h4 class="mb-1">Şifre Değiştirme</h4>
            <small style="color:#ccc;">Devam etmek için yeni bir şifre belirleyin</small>
        </div>
        <div class="card-body p-4">
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@error.ErrorMessage</div>
                    }
                </div>
            }
            <form method="post" action="/Account/ChangePassword">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label">Mevcut Şifre</label>
                    <input type="password" class="form-control" name="CurrentPassword" required>
                </div>
                <div class="mb-3">
                    <label class="form-label">Yeni Şifre</label>
                    <input type="password" class="form-control" name="NewPassword" required minlength="10">
                    <small class="text-muted">En az 8 karakter, 1 büyük harf, 1 küçük harf, 1 rakam, 1 özel karakter</small>
                </div>
                <div class="mb-3">
                    <label class="form-label">Yeni Şifre (Tekrar)</label>
                    <input type="password" class="form-control" name="ConfirmPassword" required minlength="10">
                </div>
                <button type="submit" class="btn btn-dark w-100">Şifreyi Değiştir</button>
            </form>
        </div>
    </div>
</body>
</html>